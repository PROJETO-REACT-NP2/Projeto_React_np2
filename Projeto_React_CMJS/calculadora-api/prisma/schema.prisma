generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  calculos  Calculo[]
}

model Calculo {
  id            String   @id @default(uuid())
  userId        String
  rendaMensal   Float
  custosMensais Float
  tipoCalculo   String
  profissao     String?
  impostoPF     Float?
  impostoPJ     Float?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
